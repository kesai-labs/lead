{
    "version": "0.2.0",
    "configurations": [
        // Debug configurations for Training
        {
            "name": "Pretrain NAVSIM",
            "type": "debugpy",
            "request": "launch",
            "program": "lead/training/train.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [
                "logdir=outputs/local_training/pretrain",
                "use_navsim_data=true",
                "use_carla_data=false",
                "LTF=true",
                "epochs=61"
            ],
            "env": {
                "PYTHONDONTWRITEBYTECODE": "1",
                "LEAD_TRAINING_CONFIG": "debug_mode=true"
            }
        },
        {
            "name": "Pretrain",
            "type": "debugpy",
            "request": "launch",
            "program": "lead/training/train.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [
                "logdir=outputs/local_training/pretrain"
            ],
            "env": {
                "PYTHONDONTWRITEBYTECODE": "1",
                "LEAD_TRAINING_CONFIG": "debug_mode=true"
            }
        },
        {
            "name": "Posttrain",
            "type": "debugpy",
            "request": "launch",
            "program": "lead/training/train.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [
                "logdir=outputs/local_training/posttrain",
                "load_file=outputs/local_training/pretrain/model_0030.pth",
                "use_planning_decoder=true"
            ],
            "env": {
                "PYTHONDONTWRITEBYTECODE": "1",
                "LEAD_TRAINING_CONFIG": "debug_mode=true"
            }
        },
        {
            "name": "Pretrain DDP",
            "type": "debugpy",
            "request": "launch",
            "program": "lead/training/train.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONDONTWRITEBYTECODE": "1",
                "LEAD_TRAINING_CONFIG": "debug_mode=true logdir=outputs/local_training/pretrain",
                "OMP_NUM_THREADS": "8",
                "OPENBLAS_NUM_THREADS": "1",
                "NCCL_P2P_DISABLE": "1",
                "NCCL_P2P_LEVEL": "NVL",
                "PYTORCH_CUDA_ALLOC_CONF": "expandable_segments:True"
            }
        },
        {
            "name": "Posttrain DDP",
            "type": "debugpy",
            "request": "launch",
            "program": "lead/training/train.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONDONTWRITEBYTECODE": "1",
                "LEAD_TRAINING_CONFIG": "debug_mode=true logdir=outputs/local_training/posttrain load_file=outputs/local_training/pretrain/model_0030.pth use_planning_decoder=true",
                "OMP_NUM_THREADS": "8",
                "OPENBLAS_NUM_THREADS": "1",
                "NCCL_P2P_DISABLE": "1",
                "NCCL_P2P_LEVEL": "NVL",
                "PYTORCH_CUDA_ALLOC_CONF": "expandable_segments:True"
            }
        },
        // Debug configurations for Evaluation
        {
            "name": "Eval Bench2Drive",
            "type": "debugpy",
            "request": "launch",
            "preLaunchTask": "Reset Carla World",
            "module": "lead.leaderboard_wrapper",
            "console": "integratedTerminal",
