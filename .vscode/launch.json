        // Debug configurations for Expert Evaluation / Data Generation
        {
            "name": "Expert Py123D Gen Data",
            "type": "debugpy",
            "request": "launch",
            "preLaunchTask": "Reset Carla World",
            "module": "lead.leaderboard_wrapper",
